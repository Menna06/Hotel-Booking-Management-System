@{
    // Sets the title for the browser tab
    ViewData["Title"] = "Admin Dashboard";
    // Ensures only Admin can access (good safety check)
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h1><i class="fas fa-user-shield"></i> Administrator Dashboard</h1>
    <p>Welcome back, Administrator @User.Identity.Name!</p>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body">
                    <h5 class="card-title">Room Management</h5>
                    <p class="card-text">View, add, edit, and delete hotel room details.</p>
                    <a asp-controller="Rooms" asp-action="Index" class="btn btn-primary">Go to Rooms</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body">
                    <h5 class="card-title">Booking Management</h5>
                    <p class="card-text">Manage all guest reservations and check for conflicts.</p>
                    <a asp-controller="Bookings" asp-action="Index" class="btn btn-success">Go to Bookings</a>
                </div>
            </div>
        </div>

    </div>
</div>