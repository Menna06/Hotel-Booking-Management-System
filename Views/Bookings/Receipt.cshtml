@model Hotel_Booking_Management_System.Models.ViewModels.ReceiptViewModel




<h2>Booking Receipt</h2>

<div>
    <p><strong>Guest Name:</strong> @Model.Booking.Guest.Name</p>
    <p><strong>Contact:</strong> @Model.Booking.Guest.contactInfo</p>
    <p><strong>Room Number:</strong> @Model.Booking.Room.RoomNumber</p>
    <p><strong>Room Type:</strong> @Model.Booking.Room.Type</p>
    <p><strong>Check-In:</strong> @Model.Booking.CheckIn.ToString("yyyy-MM-dd")</p>
    <p><strong>Check-Out:</strong> @Model.Booking.CheckOut.ToString("yyyy-MM-dd")</p>
    <p><strong>Total Price:</strong> $@Model.TotalPrice</p>

</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Receipt"
       asp-route-id=" @Model.Booking.Id"
       asp-route-exportToPdf="true"
       class="btn btn-danger"
       target="_blank">
        Export as PDF
    </a>
</div>


<a href="@Url.Action("Index", "Bookings")" class="btn btn-primary">Back to Bookings</a>